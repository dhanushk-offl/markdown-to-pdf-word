{
  "name": "markdown-to-pdf-word",
  "displayName": "Markdown to PDF & Word",
  "description": "Turn Markdown into a clean, professional PDF, Word, or HTML document - no Pandoc, no setup. Removes AI clutter, adds a cover page and branding.",
  "version": "1.2.3",
  "publisher": "AnandSundaramoorthySa",
  "author": {
    "name": "Anand Sundaramoorthy"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1a3d7c",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anandsundaramoorthysa/markdown-to-pdf-word.git"
  },
  "bugs": {
    "url": "https://github.com/anandsundaramoorthysa/markdown-to-pdf-word/issues"
  },
  "homepage": "https://github.com/anandsundaramoorthysa/markdown-to-pdf-word#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
    "markdown",
    "md",
    "pdf",
    "word",
    "docx",
    "html",
    "export",
    "convert",
    "document",
    "professional",
    "cleanup"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markready.openStudio",
        "title": "Markdown to PDF & Word: Open Customization Studio",
        "icon": "media/icon.png"
      },
      {
        "command": "markready.exportPdf",
        "title": "Markdown to PDF & Word: Export as PDF"
      },
      {
        "command": "markready.exportDocx",
        "title": "Markdown to PDF & Word: Export as Word (DOCX)"
      },
      {
        "command": "markready.exportHtml",
        "title": "Markdown to PDF & Word: Export as HTML"
      },
      {
        "command": "markready.cleanToNewFile",
        "title": "Markdown to PDF & Word: Clean Markdown (preview cleaned copy)"
      },
      {
        "command": "markready.exportFolder",
        "title": "Markdown to PDF & Word: Gather Folder into One Document"
      },
      {
        "command": "markready.configureAi",
        "title": "Markdown to PDF & Word: Configure AI API Key"
      },
      {
        "command": "markready.testAiKey",
        "title": "Markdown to PDF & Word: Test AI API Key"
      },
      {
        "command": "markready.clearAiKeys",
        "title": "Markdown to PDF & Word: Clear All AI API Keys"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == markdown",
          "command": "markready.openStudio",
          "group": "markready@1"
        },
        {
          "when": "resourceLangId == markdown",
          "command": "markready.exportPdf",
          "group": "markready@2"
        },
        {
          "when": "resourceLangId == markdown",
          "command": "markready.exportDocx",
          "group": "markready@3"
        }
      ],
      "editor/title": [
        {
          "when": "resourceLangId == markdown",
          "command": "markready.openStudio",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "explorerResourceIsFolder",
          "command": "markready.exportFolder",
          "group": "markready@1"
        },
        {
          "when": "resourceLangId == markdown",
          "command": "markready.openStudio",
          "group": "markready@1"
        }
      ]
    },
    "configuration": {
      "title": "Markdown to PDF & Word",
      "properties": {
        "markready.defaultProfile": {
          "type": "string",
          "default": "HR Formal",
          "description": "The document profile used by quick export commands."
        },
        "markready.chromePath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a Chrome/Edge/Chromium executable for PDF export. If empty, the extension auto-detects an installed browser (and falls back to the CHROME_PATH environment variable)."
        },
        "markready.cleanup.removeChatter": {
          "type": "boolean",
          "default": true,
          "description": "Remove AI chatty intros/outros (e.g. 'Certainly! Here's...', 'Let me know if...')."
        },
        "markready.cleanup.removeEmoji": {
          "type": "boolean",
          "default": true,
          "description": "Strip emoji from headings and text."
        },
        "markready.cleanup.normalizeHeadings": {
          "type": "boolean",
          "default": true,
          "description": "Ensure consistent heading spacing."
        },
        "markready.cleanup.normalizeWhitespace": {
          "type": "boolean",
          "default": true,
          "description": "Collapse excessive blank lines and trailing whitespace."
        },
        "markready.cleanup.normalizePunctuation": {
          "type": "boolean",
          "default": true,
          "description": "Convert smart quotes/dashes/ellipses to plain ASCII."
        },
        "markready.ai.defaultProvider": {
          "type": "string",
          "default": "openai",
          "enum": [
            "openai",
            "claude",
            "gemini",
            "openrouter"
          ],
          "description": "Default AI provider for tone polish."
        },
        "markready.ai.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Default AI model (empty = use provider default)."
        },
        "markready.ai.defaultTemperature": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "AI response creativity (0.0 = deterministic, 1.0 = creative)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "bundle": "node esbuild.js"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "diff": "^9.0.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.10.0",
    "html-to-docx": "^1.8.0",
    "katex": "^0.16.11",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-katex": "^2.0.3",
    "markdown-it-task-lists": "^2.1.1",
    "puppeteer-core": "^23.11.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
